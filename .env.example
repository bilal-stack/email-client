# Copy to .env.local and fill in real values. Never commit .env.local.

# Database — SQLite for local dev; Postgres URL for prod.
DATABASE_URL="file:./dev.db"

# Anthropic — required for any AI feature.
ANTHROPIC_API_KEY=

# Auth.js — `openssl rand -base64 32` (or `npx auth secret`).
AUTH_SECRET=

# AES-256-GCM key for encrypting provider tokens at rest. 32 bytes hex (64 chars).
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# Google OAuth — Google Cloud Console → APIs & Services → Credentials.
# Redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft Entra ID (Azure AD) — Azure Portal → App registrations.
# Redirect URI: http://localhost:3000/api/auth/callback/microsoft-entra-id
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=common

# Inngest — any string works locally; real keys only needed for prod.
INNGEST_EVENT_KEY=local-dev
INNGEST_SIGNING_KEY=local-dev
