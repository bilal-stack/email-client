# Copy to .env.local and fill in real values. Never commit .env.local.
# For production (Vercel), every var below goes into the project's Environment
# Variables tab — see docs/deploy.md for the runbook.

# ─── Required (both dev and prod) ──────────────────────────────────────
# Local dev: a Postgres connection string against your local server.
# Example: postgres://postgres:<your-password>@localhost:5432/email_client?schema=public
# On prod (Vercel): Neon's POOLED connection string with ?sslmode=require.
DATABASE_URL="postgres://postgres:postgres@localhost:5432/email_client?schema=public"

# Auth.js signing secret. Different value per environment.
# Generate: openssl rand -base64 32   (or `npx auth secret`)
AUTH_SECRET=

# AES-256-GCM key for encrypting provider tokens / IMAP passwords at rest.
# 32 bytes hex (64 chars). MUST DIFFER between dev and prod — re-using the
# dev key against prod would let a leaked dev key decrypt prod tokens.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ─── OAuth providers ───────────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials.
# Local redirect URI: http://localhost:3000/api/auth/callback/google
# Prod redirect URI:  https://<your-vercel-domain>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Azure Portal → App registrations → your app.
# Local redirect URI: http://localhost:3000/api/auth/callback/microsoft-entra-id
# Prod redirect URI:  https://<your-vercel-domain>/api/auth/callback/microsoft-entra-id
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
# `common` works for both work and personal accounts.
AZURE_AD_TENANT_ID=common

# ─── AI ────────────────────────────────────────────────────────────────
# console.anthropic.com → API Keys. Required for summary / draft / priority.
ANTHROPIC_API_KEY=

# ─── Inngest ───────────────────────────────────────────────────────────
# Local dev tolerates any non-empty value.
# Prod: app.inngest.com → your app → Event keys / Signing keys.
INNGEST_EVENT_KEY=local-dev
INNGEST_SIGNING_KEY=local-dev

# ─── Direct database URL (Prisma migrate runner) ───────────────────────
# Used by `prisma migrate` only. On local Postgres there's no PgBouncer in
# front so this is identical to DATABASE_URL — just copy the same value.
# On Neon (prod), use the dashboard's "Direct connection" URL (the one
# WITHOUT `?pgbouncer=true`) so migrations can use session-level features.
DIRECT_URL="postgres://postgres:postgres@localhost:5432/email_client?schema=public"

# ─── Production-only ───────────────────────────────────────────────────
# Explicit Auth.js base URL on prod. Auth.js v5 derives from VERCEL_URL when
# absent, but being explicit avoids edge cases with redirects across preview
# deploys. Set to https://<your-vercel-domain> (no trailing slash).
NEXTAUTH_URL=
