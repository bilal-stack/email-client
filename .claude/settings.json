{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Edit(./.env)",
      "Edit(./.env.local)",
      "Edit(./.env.production)",
      "Write(./.env)",
      "Write(./.env.local)",
      "Write(./.env.production)",
      "Read(./.env.local)",
      "Read(./.env.production)",
      "Edit(./node_modules/**)",
      "Write(./node_modules/**)",
      "Edit(./.next/**)",
      "Write(./.next/**)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/hooks/session-start.mjs",
            "timeout": 10000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/hooks/post-edit.mjs",
            "timeout": 90000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/hooks/stop.mjs",
            "timeout": 180000
          }
        ]
      }
    ]
  }
}
