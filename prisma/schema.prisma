// Foundation schema + Gmail-provider mail cache tables (Thread / Message / Attachment).
// AISummary lands in ai-summaries spec. PriorityScore lands in ai-prioritization spec.

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // `directUrl` is the un-pooled connection string. On a local Postgres /
  // pgAdmin setup it's identical to `DATABASE_URL` (no PgBouncer); on
  // Neon in production it's the dashboard's "Direct connection" URL so
  // `prisma migrate` bypasses the pooler's transaction-mode limitations.
  // Both env vars are optional; if `DIRECT_URL` isn't set Prisma falls
  // back to `url` for migrate operations too.
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── Auth.js v5 + Prisma adapter required models ─────────────────────────
model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?       @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  mailAccounts  MailAccount[]
  drafts        Draft[]
  sendTasks     SendTask[]
  createdAt     DateTime      @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Our mailbox extension ───────────────────────────────────────────────
// One row per connected mailbox. encryptedSecret is AES-256-GCM ciphertext
// holding the OAuth tokens (or, for IMAP, the SMTP/IMAP password).
model MailAccount {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider        String // "gmail" | "graph" | "imap"
  emailAddress    String
  displayName     String?
  encryptedSecret Bytes
  secretIv        Bytes
  secretTag       Bytes
  syncCursor      String? // historyId | delta token | UIDVALIDITY+UID
  lastSyncedAt    DateTime?
  createdAt       DateTime  @default(now())
  threads         Thread[]
  messages        Message[]
  drafts          Draft[]
  sendTasks       SendTask[]

  @@unique([userId, provider, emailAddress])
}

// ─── Mail cache tables (populated by provider adapters via Inngest sync) ──
model Thread {
  id               String      @id @default(cuid())
  accountId        String
  account          MailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  // Native provider thread id (Gmail threadId, Graph conversationId, or IMAP-synthesized).
  providerThreadId String
  subject          String
  lastMessageAt    DateTime
  unreadCount      Int         @default(0)
  labels           Json // string[] — provider label ids passed through
  participants     Json // CanonicalAddress[]
  messages         Message[]
  drafts           Draft[]
  sendTasks        SendTask[]
  aiSummary        AISummary?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@unique([accountId, providerThreadId])
  @@index([accountId, lastMessageAt(sort: Desc)])
}

model Message {
  id                String       @id @default(cuid())
  threadId          String
  thread            Thread       @relation(fields: [threadId], references: [id], onDelete: Cascade)
  accountId         String
  account           MailAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  providerMessageId String // Gmail messageId
  providerThreadId  String // denormalized for fast joins during sync writeback
  from              Json // CanonicalAddress
  to                Json // CanonicalAddress[]
  cc                Json // CanonicalAddress[]
  bcc               Json // CanonicalAddress[]
  subject           String
  snippet           String
  bodyHtml          String? // full HTML body; null when only text part exists
  bodyText          String?
  receivedAt        DateTime
  isUnread          Boolean      @default(false)
  labels            Json // string[] — current provider label set
  inReplyTo         String? // RFC 5322 Message-ID of parent, if any
  references        Json // string[] — RFC 5322 References chain
  attachments       Attachment[]
  priorityScore     PriorityScore?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@unique([accountId, providerMessageId])
  @@index([accountId, receivedAt(sort: Desc)])
  @@index([threadId, receivedAt(sort: Asc)])
}

model Attachment {
  id                   String    @id @default(cuid())
  messageId            String
  message              Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)
  providerAttachmentId String // Gmail's attachmentId — fetch token, not a stable global id
  filename             String
  mimeType             String
  size                 Int
  // null until the user opens / downloads the attachment. Future spec lazy-fetches the bytes.
  fetchedAt            DateTime?

  @@index([messageId])
}

// Persistent autosave slot for the composer. Source of truth lives on the
// server so a draft is resumable from any browser on any device.
//   - "new" compose (threadId = null) per user
//   - reply / reply-all / forward per (user, thread)
// SQLite treats NULL as distinct in a UNIQUE index, so the application layer
// (upsertDraftForUser) handles the threadId=null singleton via an explicit
// findFirst-then-upsert path. Cross-tab races resolve last-write-wins, which
// is documented in spec.md non-goals.
model Draft {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  accountId  String
  account    MailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  threadId   String?
  thread     Thread?  @relation(fields: [threadId], references: [id], onDelete: Cascade)

  // "new" | "reply" | "reply-all" | "forward" — validated at the Zod layer.
  mode       String

  // Recipients as JSON arrays of CanonicalAddress shape `{ name?, email }`.
  to         Json
  cc         Json
  bcc        Json

  subject    String
  bodyHtml   String

  // Reply-only — RFC 5322 header chain. JSON-string arrays.
  inReplyTo  Json
  references Json

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, threadId, mode])
  @@index([userId, updatedAt(sort: Desc)])
}

// ─── Background send queue ────────────────────────────────────────────────
// Outbound mail is sent asynchronously via Inngest: the `sendDraft` Server
// Action persists a SendTask + zero-or-more SendTaskAttachment rows and
// returns immediately. The `process-send-task` Inngest function picks the
// row up, calls the provider, records the resulting Message locally, and
// then deletes the SendTask. SSE events fire on completion/failure so the
// UI can update without a manual reload.
//
// Why a DB-backed queue rather than passing the draft inside the Inngest
// event itself: Inngest event payloads have a ~1 MB hard cap, and a single
// attachment can be up to 25 MB. Persisting bytes here lets the worker
// stream them out at send time without round-tripping through the event bus.
//
// Failed tasks are NOT auto-deleted — the UI surfaces them so the user can
// retry or discard, and the row holds the captured error for display.
model SendTask {
  id            String   @id @default(cuid())

  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  accountId     String
  account       MailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  /// "new" | "reply" | "reply-all" | "forward" — validated upstream at Zod.
  mode          String

  /// Local Thread.id if this is a reply/forward against an existing thread.
  /// `null` for a brand-new compose.
  threadId      String?
  thread        Thread?  @relation(fields: [threadId], references: [id], onDelete: SetNull)

  /// Captured at enqueue time so the worker doesn't have to re-load the
  /// thread (and so a thread deleted in-flight doesn't block the send).
  providerThreadId String?

  /// All recipient + header fields are JSON-typed to match the rest of the
  /// mail schema. Shape is the same `CanonicalAddress` and string[] the
  /// provider adapters already consume.
  to            Json
  cc            Json
  bcc           Json

  subject       String
  /// HTML body AFTER server-side sanitization. Worker passes this through
  /// to the provider verbatim.
  bodyHtml      String
  inReplyTo     String?
  references    Json

  /// Lifecycle:
  ///   queued   → enqueued, worker hasn't claimed it yet
  ///   sending  → worker is in the provider call
  ///   sent     → provider accepted; row is normally deleted shortly after
  ///   failed   → worker exhausted retries or hit a fatal error
  status        String   @default("queued")

  /// Sanitized error message when status='failed'. Never contains provider
  /// envelope detail — the worker maps via `canonicalizeProviderError`
  /// before writing here.
  error         String?

  /// Provider-assigned id once the send succeeds — used to link this row
  /// to the eventual Message row (mostly for diagnostics; the worker
  /// usually deletes the SendTask before this is queryable).
  providerMessageId String?

  /// Retry counter the worker bumps each attempt.
  attempts      Int      @default(0)

  attachments   SendTaskAttachment[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId, status])
  @@index([accountId, createdAt(sort: Desc)])
}

/// Attachment bytes for an in-flight SendTask. Kept in a separate table so
/// the SendTask row itself stays small and listable without dragging 25 MB
/// blobs into every status query. Deleted via cascade when the task is
/// removed.
model SendTaskAttachment {
  id        String   @id @default(cuid())

  taskId    String
  task      SendTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  filename  String
  mimeType  String
  size      Int
  /// Raw bytes — the worker base64-encodes these into the RFC 2822 it sends.
  content   Bytes

  createdAt DateTime @default(now())

  @@index([taskId])
}

// ─── AI summary per thread (Phase 4 ai-summaries spec) ────────────────────
// One summary per Thread (`@unique` on `threadId`). Lazy-generated on first
// thread open; the `writeDelta` invalidation hook flips `invalidatedAt` to
// non-null when a new message lands, and the next `summarizeThread` call
// regenerates via upsert. Ownership flows through `Thread.account.userId`.
model AISummary {
  id              String   @id @default(cuid())

  threadId        String   @unique
  thread          Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)

  /// Always populated — the one required field in the locked schema.
  tldr            String

  /// All three optional fields are nullable strings. The model omits them when
  /// the thread doesn't supply enough signal; the UI renders chips only for
  /// non-null fields.
  ask             String?
  decision        String?
  deadline        String?

  /// Model identifier at generation time (e.g. "claude-haiku-4-5-20251001").
  model           String

  /// Key into `lib/ai/prompts/summary-registry.ts`. Registry retains every
  /// historical prompt version indefinitely.
  promptVersion   String

  /// Raw Anthropic `usage` block — input_tokens, output_tokens, and the two
  /// cache fields. JSON keeps the column tolerant to shape evolution.
  usage           Json

  /// The serialized user payload sent to the model — subject, participants,
  /// last-N messages (bodies wrapped in <email> tags, truncated to 2 KB).
  /// Shown verbatim in the trust modal.
  userMessageJson String

  generatedAt     DateTime  @default(now())

  /// Set by the `writeDelta` invalidation hook on a new-message delta. The
  /// next `summarizeThread` call sees this non-null and regenerates, then
  /// resets to null in the upsert.
  invalidatedAt   DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ─── AI priority score per message (Phase 4 ai-prioritization spec) ──────
// One score per Message (`@unique` on `messageId`). Generated by the
// `prioritize-message` Inngest function triggered on `inbox/message.created`.
// Re-prioritization (re-run for the same message) upserts in place.
// Ownership flows through `Message.account.userId`.
model PriorityScore {
  id              String   @id @default(cuid())

  /// One score per message. Re-prioritization overwrites the row in place.
  messageId       String   @unique
  message         Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  /// 1 (noise) – 5 (urgent). Indexed for sort-by-priority queries.
  priority        Int

  /// ≤6 words, plain text (sanitized in `prioritizeMessage`). Surfaced as the
  /// row chip in the inbox.
  reason          String

  /// JSON array drawn from {"reply","archive","snooze","delegate"}.
  suggestedActions Json

  /// "phish" | "promo" | "ok". Drives the trust badge.
  riskFlag        String

  model           String
  promptVersion   String

  /// Same Anthropic `usage` shape as AISummary's usage field.
  usage           Json

  /// The serialized user payload sent to Haiku — supports a future "Show me
  /// the prompt"-style trust modal for prioritization. Not surfaced in this
  /// spec's UI, but stored so the modal can be added without re-running.
  userMessageJson String

  scoredAt        DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  /// Sort-by-priority query reads `priority` per scored message; the
  /// per-thread aggregation lives in `listThreadsForUser`. Indexing on
  /// (messageId) is already covered by the @unique.
  @@index([priority])
}
